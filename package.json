{
  "name": "gamenight-bingo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:workspace-boundaries": "bun scripts/check-workspace-boundaries.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "prepare": "husky",
    "test": "bun run typecheck && vitest run",
    "test:e2e": "playwright test",
    "test:quality-tooling": "vitest run tests/quality/tooling.test.ts",
    "test:workspace-boundaries": "bun scripts/check-workspace-boundaries.test.mjs && bun run check:workspace-boundaries",
    "typecheck": "bun run test:workspace-boundaries && tsc --noEmit --pretty false && bun run --filter '@gamenight-bingo/*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
